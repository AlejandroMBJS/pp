# =============================================================
#  ProjectPulse / Arquicheck — Variables de entorno
#  Copia este archivo a `.env` y rellena los valores reales
#  NUNCA subas .env a git (está en .gitignore)
# =============================================================

# -------- Base de datos PostgreSQL --------
DB_USER=arquicheck
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_NAME=arquicheck
# sslmode: en producción usa "require" o "verify-full" con CA.
# En desarrollo local con docker compose puedes dejar "disable".
DB_SSLMODE=require

# -------- JWT --------
# Mínimo 32 bytes aleatorios. Genera con: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_32

# -------- URLs públicas --------
# Sin barra final. Ejemplos:
#   http://123.456.78.90
#   https://app.tudominio.com
PUBLIC_BASE_URL=https://TU_DOMINIO

# CORS — orígenes separados por coma. Ejemplo:
#   ALLOWED_ORIGINS=https://app.tudominio.com,https://www.tudominio.com
ALLOWED_ORIGINS=https://TU_DOMINIO

# -------- Gemini (VisionCheck) --------
# Obtén tu key en: https://aistudio.google.com/apikey
# Si está vacía, el audit de evidencias usa un mock determinístico basado
# en el ID de la evidencia (scores 85-97, mensajes variados). Setéala para
# habilitar auditoría real con Gemini 2.0 Flash.
GEMINI_API_KEY=

# -------- Stripe (Billing) --------
# Si no usas billing, deja todas vacías.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_BUSINESS=
STRIPE_PRICE_ENTERPRISE=
BILLING_SUCCESS_URL=https://TU_DOMINIO/billing/success
BILLING_CANCEL_URL=https://TU_DOMINIO/billing

# -------- Resend (Email transaccional) --------
# https://resend.com/api-keys
# Si RESEND_API_KEY está vacío, los emails salen a stdout (ConsoleEmailSender).
# El dominio del remitente debe estar verificado en Resend.
RESEND_API_KEY=
RESEND_FROM=ProjectPulse <noreply@TU_DOMINIO>
