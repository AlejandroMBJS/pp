# =============================================================
#  Arquicheck — Variables de entorno de producción
#  Copia este archivo a .env y rellena los valores reales
#  NUNCA subas .env a git
# =============================================================

# Base de datos PostgreSQL
DB_USER=arquicheck
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_NAME=arquicheck

# JWT — mínimo 32 caracteres aleatorios (usa: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_32

# URL pública del servidor (sin barra final)
# Ejemplos: http://123.456.78.90  |  https://app.tudominio.com
PUBLIC_BASE_URL=http://TU_IP_O_DOMINIO
