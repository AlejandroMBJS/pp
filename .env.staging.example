# =============================================================
#  Staging environment — LOCAL MACHINE ONLY
#  Copiar a .env.staging y rellenar. NO se deploya al VPS.
#  Levantar con: docker compose --env-file .env.staging -p pp-staging up -d --build
# =============================================================

# Compose isolation: distinct project name so containers/volumes don't clash
# with the prod-ish dev stack on the same machine.
COMPOSE_PROJECT_NAME=pp-staging

# Gateway binding: 127.0.0.1 → sólo la máquina host puede alcanzarlo.
# Aunque el router abra puertos, el tráfico NO cruza la NIC.
GATEWAY_BIND_HOST=127.0.0.1
GATEWAY_HTTP_PORT=1213

# --- DB — isolated Postgres volume for staging ---
# The volume is named `pp-staging_postgres_data` because COMPOSE_PROJECT_NAME
# prefixes all named volumes. Setting DB creds independently from prod.
DB_USER=arquicheck
DB_PASSWORD=staging-local-password-change-me
DB_NAME=arquicheck
DB_SSLMODE=disable

# --- Auth — distinct JWT secret (prevents prod tokens from being accepted here) ---
JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_32

# --- App URLs (local only) ---
PUBLIC_BASE_URL=http://localhost:1213
ALLOWED_ORIGINS=http://localhost:1213,http://localhost:3000

# --- Gemini — optional; leave blank to use the mock auditor ---
GEMINI_API_KEY=

# --- Platform admin bootstrap ---
PLATFORM_ADMIN_EMAIL=admin@local
PLATFORM_ADMIN_PASSWORD=staging-admin

# --- Stripe — usar TEST mode keys, no live keys ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_BUSINESS=

# --- Resend (email) — opcional; si está vacío los mails se loggean a consola ---
RESEND_API_KEY=
RESEND_FROM=
